# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.gov.ph,www.yourdomain.gov.ph

# External HRIS API
HRIS_URL=https://prot1.dotr.gov.ph/api
HRIS_TOKEN=replace-with-your-hris-jwt-token
